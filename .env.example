# Copy this file to .env and fill in your values.
# .env is gitignored; .env.example is committed as a template.

# --- AWS / S3 (required: S3_BUCKET_NAME) ---
S3_BUCKET_NAME=your-bucket-name
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- Supabase Postgres (required) ---
SUPABASE_HOST=
SUPABASE_PORT=5432
SUPABASE_USER=
SUPABASE_PASSWORD=
SUPABASE_DATABASE=postgres

# --- Anthropic (required for the insights step) ---
ANTHROPIC_API_KEY=

# --- Email (Resend) (optional - email step is skipped if either is empty) ---
RESEND_API_KEY=
FROM_EMAIL=
REPLY_TO_EMAIL=

# --- Client config (defaults shown; override per-client as needed) ---
CLIENT_NAME=Juice Bar NYC
REPORT_RECIPIENT_EMAIL=
BUSINESS_TYPE=Juice Bar

# --- Local paths ---
DB_PATH=data/clearpath.db
